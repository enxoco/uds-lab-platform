# Hetzner Cloud — required
HCLOUD_TOKEN=your_hetzner_token_here

# GitHub OAuth App — required for auth gate
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://uds-labs.hackanooga.com/auth/callback

# Workshop access code — required for auth gate
WORKSHOP_CODE=SCS-HERO-2026

# Comma-separated GitHub usernames with admin access
ADMIN_USERS=your-github-username

# Scenario authoring — omit to use read-only embedded scenarios
# DB_PATH is set automatically in compose.yaml (/data/lab.db via named volume)
# Only needed if running outside Docker
# DB_PATH=/data/lab.db

# GitHub App — optional, enables pull/export/webhook (not yet implemented)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=          # base64 -w0 app.pem
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_WEBHOOK_SECRET=

# Optional overrides
SESSION_TTL_MINUTES=60
VM_SERVER_TYPE=ccx13
VM_LOCATION=hil
