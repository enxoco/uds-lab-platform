{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "domain",
    "image",
    "imagePullPolicy",
    "vmNamespace",
    "sessionTTLMinutes",
    "provider",
    "goldenPVCs",
    "goldenPVCNamespace",
    "goldenPVCDiskSize"
  ],
  "properties": {
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string",
      "minLength": 1
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"]
    },
    "vmNamespace": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "sessionTTLMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "provider": {
      "type": "string",
      "enum": ["kubevirt", "pod"]
    },
    "goldenPVCs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "goldenPVCNamespace": {
      "type": "string"
    },
    "goldenPVCDiskSize": {
      "type": "string",
      "minLength": 1
    }
  }
}
